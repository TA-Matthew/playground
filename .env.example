# Required for expiring participant links (Railway / local dev server)
SHARE_LINK_SECRET=replace-with-long-random-string

# Optional: require Bearer token on POST /api/share/create
# SHARE_CREATE_KEY=

# Optional: canonical origin when creating links (else derived from request Host)
# PUBLIC_URL=https://your-app.up.railway.app

# Server port (Railway sets PORT automatically)
# PORT=3000
